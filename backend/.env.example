PORT=5000
SECRET_KEY=troque-me
DEBUG=false

# Em produção, use a URL interna do banco
INTERNAL_DATABASE_URL=postgresql://user:password@host:5432/dbname

# Em debug local, use a URL externa
EXTERNAL_DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Redis para sincronização entre instâncias
REDIS_URL=redis://localhost:6379
