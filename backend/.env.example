# backend/.env.example
# Copie para .env e preencha os valores

# Papel deste servidor: "primary" ou "replica"
ROLE=primary

# Porta TCP deste servidor
PORT=5000

# Porta do servidor primário (usada pela réplica no failover)
PRIMARY_PORT=5000

# Banco de dados PostgreSQL
INTERNAL_DATABASE_URL=postgresql://user:senha@host-interno/socketext
EXTERNAL_DATABASE_URL=postgresql://user:senha@host-externo/socketext

# true = usa EXTERNAL_DATABASE_URL (desenvolvimento local)
DEBUG=false

# Redis (heartbeat e pub/sub)
REDIS_URL=redis://localhost:6379

# Número de mensagens no histórico inicial
HISTORY_LIMIT=50

# Intervalo entre heartbeats do primário (segundos)
HEARTBEAT_INTERVAL=2

# Timeout para failover da réplica (segundos)
FAILOVER_TIMEOUT=6
