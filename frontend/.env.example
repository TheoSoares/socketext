# frontend/.env.example
# Copie para .env e preencha os valores

# Chave secreta do Flask (deve ser igual à do backend)
SECRET_KEY=troque-por-uma-chave-segura-e-aleatoria

# Endereços dos servidores backend TCP, separados por vírgula
# Formato: host:porta
BACKEND_SERVERS=localhost:5000,localhost:5001

# Porta em que o frontend HTTP irá escutar
PORT=8000
